# Email destinatario (tu)
DIGEST_TO_EMAIL=tuo@email.com

# SMTP — es. Gmail con "Password per le app"
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tuo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
DIGEST_FROM_EMAIL=tuo@gmail.com
DIGEST_FROM_NAME=Job Digest IT

# Adzuna API gratuita — https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble API gratuita — https://jooble.org/api/about
JOOBLE_API_KEY=

# Opzionale: quanti annunci max in email (default 12)
DIGEST_MAX_JOBS=12

# Opzionale: score minimo 0-100 (default 60)
DIGEST_MIN_SCORE=60

# Web app annunci (npm run web)
WEB_PORT=3847
# WEB_HOST=0.0.0.0
# WEB_TOKEN=imposta_un_token_segreto

# LinkedIn (opzionale, solo locale)
# mode: guest | browser | hybrid (default hybrid)
# 1) guest: API pubblica senza login
# 2) browser: Playwright con sessione salvata (npm run linkedin:login)
# 3) hybrid: guest prima, fallback browser se bloccato
LINKEDIN_SESSION_PATH=data/linkedin-session.json
# LINKEDIN_MODE=hybrid
# LINKEDIN_HEADLESS=false

# Email destinatario (tu)
DIGEST_TO_EMAIL=tuo@email.com

# SMTP — es. Gmail con "Password per le app"
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tuo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
DIGEST_FROM_EMAIL=tuo@gmail.com
DIGEST_FROM_NAME=Job Digest IT

# Adzuna API gratuita — https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Opzionale: quanti annunci max in email (default 12)
DIGEST_MAX_JOBS=12

# Opzionale: score minimo 0-100 (default 45)
DIGEST_MIN_SCORE=45
